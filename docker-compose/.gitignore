# Secrets directory (contains Vault keys)
secrets/

# Environment file with sensitive data
.env

# Customer-specific config files (contain secrets like Vault tokens and WG keys)
customer-config.sh
customer-config.alpha
customer-config.beta
customer-config.gamma

# Runtime-generated APISIX config (regenerated by apisix-init on each `up`).
# Keep the directory (.gitkeep) but not the generated file.
config/apisix/generated/apisix.yaml
