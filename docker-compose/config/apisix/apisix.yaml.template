upstreams:
  - id: "mxengine"
    nodes:
      "mxengine:8080": 1
    type: roundrobin

  - id: "policy"
    nodes:
      "policy:8080": 1
    type: roundrobin

  - id: "smimekeys"
    nodes:
      "smimekeys-client:8080": 1
    type: roundrobin

  - id: "mtaconf"
    nodes:
      "mtaconf:8080": 1
    type: roundrobin

  - id: "irisagent"
    nodes:
      "irisagent:8080": 1
    type: roundrobin

plugin_configs:
  - id: "oidc-bearer"
    plugins:
      openid-connect:
        client_id: apisix
        client_secret: ${KEYCLOAK_APISIX_CLIENT_SECRET}
        discovery: http://host.docker.internal:8181/realms/stargate/.well-known/openid-configuration
        bearer_only: true
        realm: stargate
        introspection_endpoint: http://host.docker.internal:8181/realms/stargate/protocol/openid-connect/token/introspect
        introspection_endpoint_auth_method: client_secret_post
        set_access_token_header: true
        access_token_in_authorization_header: true

routes:
  # ==================
  # Liveness routes — no auth, direct pass-through
  # ==================
  - id: "mxengine-liveness"
    uri: "/mxengine/liveness"
    upstream_id: "mxengine"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/mxengine/(.*)", "/$1"]

  - id: "policy-liveness"
    uri: "/policy/liveness"
    upstream_id: "policy"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/policy/(.*)", "/$1"]

  - id: "smimekeys-liveness"
    uri: "/smimekeys/liveness"
    upstream_id: "smimekeys"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/smimekeys/(.*)", "/$1"]

  - id: "mtaconf-liveness"
    uri: "/mtaconf/liveness"
    upstream_id: "mtaconf"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/mtaconf/(.*)", "/$1"]

  - id: "irisagent-liveness"
    uri: "/irisagent/liveness"
    upstream_id: "irisagent"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/irisagent/(.*)", "/$1"]

  # ==================
  # Internal routes — IP-restricted, no auth
  # In Docker Compose all containers share stargate-network, so these are
  # reachable by any container. Restriction mirrors the k8s cluster-internal
  # model; tighten by removing APISIX host-port exposure if needed.
  # ==================
  - id: "irisagent-internal"
    uris:
      - "/irisagent/v1/connections"
      - "/irisagent/v1/connections/*"
      - "/irisagent/v1/peers"
      - "/irisagent/v1/peers/*"
      - "/irisagent/v1/wg/public-key"
      - "/irisagent/v1/message"
    upstream_id: "irisagent"
    priority: 100
    plugins:
      proxy-rewrite:
        regex_uri: ["^/irisagent/(.*)", "/$1"]
      ip-restriction:
        whitelist:
          - "127.0.0.1"
          - "172.16.0.0/12"

  - id: "smimekeys-internal"
    uris:
      - "/smimekeys/v1/certs/peers/sync"
      - "/smimekeys/v1/rootca"
      - "/smimekeys/v1/domains"
    upstream_id: "smimekeys"
    priority: 100
    plugins:
      proxy-rewrite:
        regex_uri: ["^/smimekeys/(.*)", "/$1"]
      ip-restriction:
        whitelist:
          - "127.0.0.1"
          - "172.16.0.0/12"

  # ==================
  # Authenticated routes — Bearer token required via Keycloak OIDC
  # ==================
  - id: "mxengine-route"
    uri: "/mxengine/*"
    upstream_id: "mxengine"
    plugin_config_id: "oidc-bearer"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/mxengine/(.*)", "/$1"]

  - id: "policy-route"
    uri: "/policy/*"
    upstream_id: "policy"
    plugin_config_id: "oidc-bearer"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/policy/(.*)", "/$1"]

  - id: "smimekeys-route"
    uri: "/smimekeys/*"
    upstream_id: "smimekeys"
    plugin_config_id: "oidc-bearer"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/smimekeys/(.*)", "/$1"]

  - id: "mtaconf-route"
    uri: "/mtaconf/*"
    upstream_id: "mtaconf"
    plugin_config_id: "oidc-bearer"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/mtaconf/(.*)", "/$1"]

  - id: "irisagent-route"
    uri: "/irisagent/*"
    upstream_id: "irisagent"
    plugin_config_id: "oidc-bearer"
    plugins:
      proxy-rewrite:
        regex_uri: ["^/irisagent/(.*)", "/$1"]

#END
