// Env vars (set in docker-compose):
//   LOCAL_LOKI_URL  — Local Loki push URL (always http://loki:3100)
//   ALLOY_HOSTNAME  — deployment id (used for `host`/`environment` labels)
//
// Remote log shipping is managed by the dashboard service: the dashboard serves a
// `log_collection` module (imported below) whose exported `receiver` ships logs to
// the remote Loki URL configured in the dashboard. When no remote URL is set, the
// module's receiver is a no-op and only the local write below applies. Local Loki
// is always written here — the dashboard reads it for log export.

logging {
  level  = "info"
  format = "logfmt"
}


import.http "dashboard" {
  url            = "http://dashboard:3000/api/internal/alloy"
  poll_frequency = "1m"
}

// Instantiate the dashboard-served module. Its exported `receiver` is the remote
// sink: it ships to the remote Loki URL the dashboard is configured with (and is
// a no-op when the dashboard has no remote URL set).
dashboard.log_collection "default" { }

discovery.docker "stargate" {
  host             = "unix:///var/run/docker.sock"
  refresh_interval = "5s"

  filter {
    name   = "name"
    values = [
      "stargate-apisix",
      "stargate-keycloak",
      "stargate-dashboard",
      "stargate-smimekeys-client",
      "stargate-policy",
      "stargate-policy-sync",
      "stargate-irisagent",
      "stargate-mxengine",
    ]
  }
}

discovery.relabel "stargate" {
  targets = discovery.docker.stargate.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/stargate-(apisix|keycloak|dashboard|smimekeys-client|policy|policy-sync|irisagent|mxengine)"
    action        = "keep"
  }

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/stargate-(.*)"
    target_label  = "service"
  }

  rule {
    target_label = "environment"
    replacement  = sys.env("ALLOY_HOSTNAME")
  }

  rule {
    target_label = "host"
    replacement  = sys.env("ALLOY_HOSTNAME")
  }
}

loki.source.docker "stargate" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.stargate.output
  forward_to = [loki.process.stargate.receiver]
}

loki.process "stargate" {
  stage.json {
    expressions = {
      level   = "level",
      msg     = "msg",
      message = "message",
      ts      = "ts",
      time    = "time",
    }
  }

  stage.regex {
    expression = "(?P<level>INFO|WARN|ERROR|DEBUG|info|warn|error|debug)"
  }

  stage.labels {
    values = { level = "level" }
  }

  forward_to = concat([loki.write.local.receiver], dashboard.log_collection.default.receivers)

}

// Always write to local Loki (used by the dashboard for log export).
// Remote shipping is handled by dashboard.log_collection above.
loki.write "local" {
  endpoint {
    url = sys.env("LOCAL_LOKI_URL") + "/loki/api/v1/push"
  }
}
