{
  "id": "stargate",
  "realm": "stargate",
  "displayName": "HIN Gateway",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "app-admin",
        "description": "Application administrator"
      },
      {
        "name": "app-user",
        "description": "Application user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "apisix",
      "name": "APISIX Gateway",
      "description": "Confidential client used by APISIX for token introspection",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_APISIX_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "bearerOnly": false
    },
    {
      "clientId": "dashboard",
      "name": "Dashboard",
      "description": "Confidential client for the Next.js dashboard application",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_DASHBOARD_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["${DASHBOARD_PUBLIC_URL}/*"],
      "webOrigins": ["${DASHBOARD_PUBLIC_URL}"],
      "protocolMappers": [
        {
          "name": "apisix-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "apisix",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "lightweight.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "dozzle",
      "name": "Dozzle",
      "description": "Confidential client for the Dozzle log viewer (fronted by oauth2-proxy)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_DOZZLE_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["${DOZZLE_PUBLIC_URL}/oauth2/callback"],
      "webOrigins": ["${DOZZLE_PUBLIC_URL}"]
    },
    {
      "clientId": "app",
      "name": "Application",
      "description": "Public PKCE client for frontend SPA usage",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": ["${DASHBOARD_PUBLIC_URL}/*"],
      "webOrigins": ["${DASHBOARD_PUBLIC_URL}"]
    }
  ],
  "users": [
    {
      "username": "sg-admin",
      "enabled": true,
      "email": "sg.admin@hin.ch",
      "emailVerified": true,
      "requiredActions": ["UPDATE_PASSWORD"],
      "realmRoles": ["app-admin"],
      "credentials": [
        {
          "type": "password",
          "value": "QuickL0gin!",
          "temporary": true
        }
      ]
    }
  ]
}
