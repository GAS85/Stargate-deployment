# ===================
# PostgreSQL
# ===================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===================
# Vault
# ===================
# This will be auto-generated on first run if not set
# Leave empty for auto-generation
VAULT_TOKEN=

# ===================
# MinIO (S3)
# ===================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
S3_BUCKET_NAME=svdh-bucket

# ===================
# Application Versions
# ===================
# Use 'latest' or specific version tags
SMIMEKEYS_VERSION=latest
POLICY_VERSION=latest
IDAGENT_VERSION=latest
MXENGINE_VERSION=latest

# ===================
# Docker Registry
# ===================
# If you need to login to the registry, run:
# docker login registry.vereign.io
