# ===================
# PostgreSQL
# ===================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===================
# Vault
# ===================
# Auto-generated during Vault initialization - DO NOT SET MANUALLY
# Vault 1.19+ does not support custom root tokens
# This is populated by install.sh after Vault init
VAULT_TOKEN=

# ===================
# MinIO (S3)
# ===================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
S3_BUCKET_NAME=stargate-bucket

# ===================
# Application Versions
# ===================
# Use 'latest' or specific version tags
SMIMEKEYS_VERSION=dev
POLICY_VERSION=dev
IRISAGENT_VERSION=dev
MXENGINE_VERSION=dev
DASHBOARD_VERSION=dev
POSTFIXCONF_VERSION=dev

# ===================
# Docker Registry
# ===================
# If you need to login to the registry, run:
# docker login registry.vereign.io

# ===================
# Mail Outbound Path
# ===================
# Mail flow: Port 25 → content_filter → mxengine:1587 → Port 10026 → relay to MX
#
# Domains and hostname are configured at runtime by the dashboard via the
# postfixconf REST API (POST /v1/config).

# MXEngine public address (auto-derived from SERVER_STATIC_IP if empty)
MXENGINE_PUBLIC_ADDRESS=

# Sealer MX domain for outbound seal delivery
OUTBOUND_SEALER_MX_DOMAIN=hintest.ch

# CA IRISAgent domain for certificate issuance via WireGuard tunnel
CERT_CA_IRISAGENT_DOMAIN=hintest.ch

# Outbound SMTP host/port for mxengine delivery (default: postfixconf:10026)
# Set these if using an external Postfix server
OUTBOUND_SMTP_HOST=postfixconf
OUTBOUND_SMTP_PORT=10026

# MXEngine integration (default: mxengine:1587)
MXENGINE_HOST=mxengine
MXENGINE_PORT=1587

# ===================
# Logging (Alloy -> Loki)
# ===================
# Loki push URL (leave empty to skip log shipping)
LOKI_URL=

# Hostname label for logs (also used as the remotecfg collector id)
ALLOY_HOSTNAME=stargate

# ===================
# Keycloak
# ===================
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

KEYCLOAK_APISIX_CLIENT_SECRET=changeme
KEYCLOAK_DASHBOARD_CLIENT_SECRET=changeme

# Public-facing URLs used by the dashboard to redirect to Keycloak
# (browser-side — must be reachable from the end-user's machine)
KEYCLOAK_PUBLIC_URL=http://localhost:8180

# ===================
# APISIX
# ===================
# Admin API key (used for the read-only debug admin endpoint on port 9180)
APISIX_ADMIN_KEY=changeme

# ===================
# Deployment Identity
# ===================
CUSTOMER_NAME=
DEPLOYMENT_NAME=

# ===================
# Dashboard
# ===================
# Public URL for the dashboard (used in Next.js NEXT_PUBLIC_APP_URL)
DASHBOARD_PUBLIC_URL=https://localhost
# Show developer-only pages in the UI
DASHBOARD_SHOW_DEV_PAGES=false
KEYCLOAK_DASHBOARD_CLIENT_ID=dashboard
# Root URL / domain used for cross-origin dashboard embedding (optional)
DASHBOARD_ROOT_URL=https://apisix.k8s.vereign-cdn.com
DASHBOARD_ROOT_DOMAIN=vereign-cdn.com

# ===================
# WireGuard (IRISAgent tunnels)
# ===================
# WG_LOCAL_IP is auto-derived from SERVER_STATIC_IP in customer-config.sh.
# Only set here if you need a different tunnel address.
WG_LOCAL_IP=YOUR_SERVER_STATIC_IP

# Port for WireGuard tunnel traffic (both TCP and UDP are exposed)
WG_INTERFACE_PORT=19818

# Transport mode: "tcp" (default) or "udp"
WG_TRANSPORT_MODE=tcp

# WireGuard private key (optional - auto-generated by irisagent if empty)
WG_PRIVATE_KEY=

# ===================
# Policy Sync (optional)
# ===================
# Enable by adding --profile policy-sync to docker compose up
POLICY_SYNC_VERSION=dev
POLICY_SYNC_REPO_URL=
POLICY_SYNC_REPO_USER=
POLICY_SYNC_REPO_PASS=
POLICY_SYNC_REPO_BRANCH=
POLICY_SYNC_REPO_FOLDER=
POLICY_SYNC_INTERVAL=1h

# ===================
# Dozzle Log Viewer (optional)
# ===================
# Enable by adding --profile dozzle to docker compose up
DOZZLE_VERSION=v10.5.0
DOZZLE_ENABLED=false
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=
